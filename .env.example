# 복사해서 .env 로 만들고 값을 채우세요. (.env 는 gitignore 됨)
# 비어 있으면 앱은 플레이스홀더로 동작하지만 실제 호출은 실패해요.

# Supabase (대시보드 > Project Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 앱인토스 콘솔 > 수익화 > 인앱광고에서 daily-vote 앱으로 발급한 광고 그룹 ID
# 비우면 보상형은 즉시 통과(개발/브라우저에서 흐름이 안 끊겨요), 전면/배너는 건너뜀
VITE_AD_GROUP_ID_REWARDED=
VITE_AD_GROUP_ID_INTERSTITIAL=
VITE_AD_GROUP_ID_BANNER=

# 스마트 발송 알림 동의 템플릿 코드 (비우면 건너뜀)
VITE_NOTIFY_TEMPLATE_CODE=
